      "import": "./dist/tool.js"
    },
    "./audience": {
      "types": "./src/audience.ts",
      "development": "./src/audience.ts",
      "import": "./dist/audience.js"
    },
    "./llm": {
      "types": "./src/llm.ts",
      "development": "./src/llm.ts",
      "import": "./dist/llm.js"
    },
    "./report": {
      "types": "./src/report.ts",
      "development": "./src/report.ts",
      "import": "./dist/report.js"
    },
    "./run": {
      "types": "./src/run.ts",
      "development": "./src/run.ts",
      "import": "./dist/run.js"
    },
    "./live-events": {
      "types": "./src/live-events.ts",
      "development": "./src/live-events.ts",
      "import": "./dist/live-events.js"
    }
