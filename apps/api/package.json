{
  "name": "@trycue/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --dir src --exclude \"**/*.integration.test.ts\"",
    "test:integration": "vitest run -c vitest.integration.config.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.68",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.3.0",
    "@fastify/static": "^9.1.3",
    "@trycue/db": "workspace:*",
    "@trycue/shared": "workspace:*",
    "ai": "^6.0.198",
    "fastify": "^5.8.5",
    "image-size": "^2.0.2",
    "openai": "^6.10.0",
    "yaml": "^2.9.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "vitest": "^4.1.7"
  }
}
