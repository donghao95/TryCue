{
  "name": "@trycue/api",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --dir src --exclude \"**/*.integration.test.ts\"",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:integration:smoke": "vitest run -c vitest.integration.smoke.config.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.4",
    "@ai-sdk/openai-compatible": "^3.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.3.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^9.1.3",
    "@trycue/db": "workspace:*",
    "@trycue/shared": "workspace:*",
    "ai": "^7.0.9",
    "fastify": "^5.8.5",
    "image-size": "^2.0.2",
    "openai": "^6.45.0",
    "yaml": "^2.9.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  }
}
