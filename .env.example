APP_ENV=local
APP_URL=http://localhost:3000
API_PORT=4000

DATABASE_URL=file:./data/trycue.db

LLM_CONFIG_PATH=config/llm.local.yaml
SCHEDULER_WORKER_ID=local-worker-1
SCHEDULER_DEFAULT_CONCURRENCY=2
SCHEDULER_ACTION_TIMEOUT_SECONDS=120
SCHEDULER_MAX_RETRY=2
DEFAULT_STANDARD_AUDIENCE_COUNT=30
DEFAULT_QUICK_AUDIENCE_COUNT=12
MAX_JOURNEY_ACTIONS_PER_JOURNEY=10
MAX_TOOL_CALLS_PER_ACTION=20
REALTIME_MODE=sse
SSE_HEARTBEAT_INTERVAL=15
SSE_TIMEOUT_SECONDS=300
MAX_COVER_IMAGE_SIZE_MB=5
STORAGE_PROVIDER=local
STORAGE_BUCKET=ai-screening
LOG_LEVEL=debug
ENABLE_AGENT_TRACE=true
ENABLE_REPORT_GENERATION=true
ENABLE_PROMPT_REPAIR=true
ENABLE_DEBUG_PAGE=true
ENABLE_SCHEDULER=true

# Mock agent display delay (ms). Default 0 (no delay) keeps test/dev behavior identical.
# Set to 2000 for local demo to see the real-time thinking process.
MOCK_AGENT_DELAY_MS=0
